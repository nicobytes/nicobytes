---
import { Image } from "astro:assets";
import { getCollection, render, type CollectionEntry } from "astro:content";
import BackButton from "../../components/BackButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import Prose from "../../components/Prose.astro";
import { formatDate } from "../../lib/formatDate";
import { getOgImageUrl } from "../../lib/getOgImageUrl";
import { blogPostingSchema } from "../../lib/seo/jsonLd";
import "katex/dist/katex.min.css";

type BlogEntry = CollectionEntry<"blog">;

interface AlternateLink {
  href: string;
  label: string;
  hreflang: "en" | "es";
}

function getBaseSlug(post: BlogEntry) {
  if (post.data.lang === "es" && post.id.endsWith("/es")) {
    return post.id.slice(0, -3);
  }

  return post.id;
}

function getPostPath(post: BlogEntry, baseSlug = getBaseSlug(post)) {
  if (post.data.lang === "es") {
    return `/blog/es/${post.data.translationSlug ?? baseSlug}/`;
  }

  return `/blog/${baseSlug}/`;
}

export async function getStaticPaths() {
  const getStaticBaseSlug = (post: BlogEntry) => {
    if (post.data.lang === "es" && post.id.endsWith("/es")) {
      return post.id.slice(0, -3);
    }

    return post.id;
  };
  const getStaticPostPath = (post: BlogEntry, baseSlug = getStaticBaseSlug(post)) =>
    post.data.lang === "es"
      ? `/blog/es/${post.data.translationSlug ?? baseSlug}/`
      : `/blog/${baseSlug}/`;
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const groups = new Map<string, { en?: BlogEntry; es?: BlogEntry }>();

  for (const post of posts) {
    const baseSlug = getStaticBaseSlug(post);
    const group = groups.get(baseSlug) ?? {};

    group[post.data.lang] = post;
    groups.set(baseSlug, group);
  }

  return Array.from(groups.entries()).flatMap(([baseSlug, group]) => {
    const paths = [];

    if (group.en) {
      const alternate = group.es
        ? {
            href: getStaticPostPath(group.es, baseSlug),
            label: "Leer en español",
            hreflang: "es" as const,
          }
        : undefined;

      paths.push({
        params: { slug: baseSlug },
        props: { post: group.en, baseSlug, alternate },
      });
    }

    if (group.es) {
      const alternate = group.en
        ? {
            href: getStaticPostPath(group.en, baseSlug),
            label: "Read in English",
            hreflang: "en" as const,
          }
        : undefined;

      paths.push({
        params: {
          slug: `es/${group.es.data.translationSlug ?? baseSlug}`,
        },
        props: { post: group.es, baseSlug, alternate },
      });
    }

    return paths;
  });
}

const { post, baseSlug, alternate } = Astro.props as {
  post: BlogEntry;
  baseSlug: string;
  alternate?: AlternateLink;
};
const { Content } = await render(post);
const { url: ogImage, width: ogImageWidth, height: ogImageHeight } =
  await getOgImageUrl(post.data.heroImage, Astro.site);
const site = Astro.site ?? "https://nicobytes.com";
const postPath = getPostPath(post, baseSlug);
const postUrl = new URL(postPath, site).href;
const alternateUrl = alternate ? new URL(alternate.href, site).href : undefined;
const defaultUrl =
  post.data.lang === "en"
    ? postUrl
    : alternate?.hreflang === "en"
      ? alternateUrl
      : undefined;
const alternates = [
  { href: postUrl, hreflang: post.data.lang },
  ...(alternateUrl && alternate
    ? [{ href: alternateUrl, hreflang: alternate.hreflang }]
    : []),
  ...(defaultUrl ? [{ href: defaultUrl, hreflang: "x-default" }] : []),
];
const dateLocale = post.data.lang === "es" ? "es-CO" : "en-US";
const pageLang = post.data.lang === "es" ? "es-CO" : "en";
const backButtonLabel =
  post.data.lang === "es" ? "Volver al blog" : "Go back to blog";
const repoButtonLabel =
  post.data.lang === "es" ? "Ver repositorio" : "View repo";
const jsonLd = blogPostingSchema({
  title: post.data.title,
  description: post.data.description,
  url: postUrl,
  datePublished: post.data.date,
  image: ogImage,
  author: post.data.author,
  inLanguage: pageLang,
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  imageWidth={ogImageWidth}
  imageHeight={ogImageHeight}
  type="article"
  publishedTime={post.data.date}
  author={post.data.author}
  jsonLd={jsonLd}
  lang={pageLang}
  alternates={alternates}
>
  <Container class="mt-12 lg:mt-24">
    <div class="xl:relative">
      <div class="mx-auto max-w-2xl">
        <BackButton label={backButtonLabel} />
        <article>
          {
            post.data.heroImage && (
              <figure class="mb-6 overflow-hidden rounded-2xl shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:ring-white/10">
                <Image
                  src={post.data.heroImage}
                  alt={post.data.title}
                  widths={[672, 1024, 1344]}
                  sizes="(min-width: 42rem) 42rem, 100vw"
                  quality={85}
                  format="webp"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  class="h-auto w-full object-cover md:max-h-[480px]"
                />
              </figure>
            )
          }
          <header class="flex flex-col">
            <h1
              class="mt-4 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
            >
              {post.data.title}
            </h1>
            <div class="order-first flex flex-wrap items-center gap-x-4 gap-y-2 text-base text-zinc-500 dark:text-zinc-400">
              <time datetime={post.data.date} class="flex items-center">
                <span
                  class="h-4 w-0.5 rounded-full"
                  style="background: var(--accent-gradient);"></span>
                <span class="ml-3">
                  {formatDate(post.data.date, dateLocale)}
                </span>
              </time>
              {
                alternate && (
                  <a
                    href={alternate.href}
                    hreflang={alternate.hreflang}
                    class="text-sm font-medium text-teal-500 transition hover:text-teal-600 dark:text-teal-400 dark:hover:text-teal-300"
                  >
                    {alternate.label}
                  </a>
                )
              }
            </div>
          </header>
          <Prose class="mt-6" data-mdx-content>
            <Content />
          </Prose>
          {
            post.data.repoLink && (
              <Button
                href={post.data.repoLink}
                target="_blank"
                rel="noopener noreferrer"
                variant="secondary"
                class="group mt-8 w-full"
              >
                {repoButtonLabel}
                <svg
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="h-4 w-4 stroke-zinc-400 transition group-active:stroke-zinc-600 dark:group-hover:stroke-zinc-50 dark:group-active:stroke-zinc-50"
                >
                  <path
                    d="M4.75 11.25 11.25 4.75M4.75 4.75h6.5v6.5"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </Button>
            )
          }
        </article>
      </div>
    </div>
  </Container>
</BaseLayout>
