---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BackButton from "../../components/BackButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import Prose from "../../components/Prose.astro";
import { formatDate } from "../../lib/formatDate";
import { getOgImageUrl } from "../../lib/getOgImageUrl";
import { blogPostingSchema } from "../../lib/seo/jsonLd";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const ogImage = await getOgImageUrl(post.data.heroImage, Astro.site);
const postUrl = new URL(`/blog/${post.id}/`, Astro.site).href;
const jsonLd = blogPostingSchema({
  title: post.data.title,
  description: post.data.description,
  url: postUrl,
  datePublished: post.data.date,
  image: ogImage,
  author: post.data.author,
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  type="article"
  publishedTime={post.data.date}
  author={post.data.author}
  jsonLd={jsonLd}
>
  <Container class="mt-12 lg:mt-24">
    <div class="xl:relative">
      <div class="mx-auto max-w-2xl">
        <BackButton label="Go back to blog" />
        <article>
          {
            post.data.heroImage && (
              <figure class="mb-6 overflow-hidden rounded-2xl shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:ring-white/10">
                <Image
                  src={post.data.heroImage}
                  alt={post.data.title}
                  widths={[672, 1024, 1344]}
                  sizes="(min-width: 42rem) 42rem, 100vw"
                  quality={85}
                  format="webp"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  class="h-auto w-full object-cover md:max-h-[480px]"
                />
              </figure>
            )
          }
          <header class="flex flex-col">
            <h1
              class="mt-4 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
            >
              {post.data.title}
            </h1>
            <time
              datetime={post.data.date}
              class="order-first flex items-center text-base text-zinc-500 dark:text-zinc-400"
            >
              <span
                class="h-4 w-0.5 rounded-full"
                style="background: var(--accent-gradient);"></span>
              <span class="ml-3">{formatDate(post.data.date)}</span>
            </time>
          </header>
          <Prose class="mt-6" data-mdx-content>
            <Content />
          </Prose>
          {
            post.data.repoLink && (
              <Button
                href={post.data.repoLink}
                target="_blank"
                rel="noopener noreferrer"
                variant="secondary"
                class="group mt-8 w-full"
              >
                View repo
                <svg
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="h-4 w-4 stroke-zinc-400 transition group-active:stroke-zinc-600 dark:group-hover:stroke-zinc-50 dark:group-active:stroke-zinc-50"
                >
                  <path
                    d="M4.75 11.25 11.25 4.75M4.75 4.75h6.5v6.5"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </Button>
            )
          }
        </article>
      </div>
    </div>
  </Container>
</BaseLayout>
