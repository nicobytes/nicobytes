---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import clsx from "clsx";
import { Icon } from "astro-icon/components";

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Card from "../components/Card.astro";
import CardTitle from "../components/CardTitle.astro";
import CardDescription from "../components/CardDescription.astro";
import CardCta from "../components/CardCta.astro";
import CardEyebrow from "../components/CardEyebrow.astro";
import Resume from "../components/Resume.astro";
import { getYearsOfExperience } from "../lib/experience";
import { formatDate } from "../lib/formatDate";
import { socialLinks } from "../lib/socialLinks";
import {
  personSchema,
  websiteSchema,
} from "../lib/seo/jsonLd";

import image1 from "../assets/images/photos/image-4.png";
import image2 from "../assets/images/photos/image-3.png";
import image3 from "../assets/images/photos/image-6.png";
import image4 from "../assets/images/photos/image-4.jpg";
import image5 from "../assets/images/photos/image-2.jpg";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, z) => +new Date(z.data.date) - +new Date(a.data.date))
  .slice(0, 4);

type HeroPhoto = {
  src: typeof image1;
  alt: string;
  rotation: string;
  loading: "lazy" | "eager";
  fetchpriority?: "high";
};

const heroPhotos: HeroPhoto[] = [
  {
    src: image1,
    alt: "Nicolas Molina at a tech conference",
    rotation: "rotate-2",
    loading: "lazy",
  },
  {
    src: image2,
    alt: "Nicolas Molina speaking on stage",
    rotation: "-rotate-2",
    loading: "eager",
  },
  {
    src: image3,
    alt: "Nicolas Molina at a developer meetup",
    rotation: "rotate-2",
    loading: "eager",
    fetchpriority: "high",
  },
  {
    src: image4,
    alt: "Nicolas Molina at a community event",
    rotation: "rotate-2",
    loading: "eager",
  },
  {
    src: image5,
    alt: "Nicolas Molina at a workshop",
    rotation: "-rotate-2",
    loading: "lazy",
  },
];

const yearsOfExperience = getYearsOfExperience();

const homeDescription = `Senior Software Engineer and Google Developer Expert building AI products, frontend platforms, and developer tools. Microsoft MVP with ${yearsOfExperience}+ years of experience.`;

const siteUrl = Astro.site?.href ?? "https://nicobytes.com/";
const homeJsonLd = [
  websiteSchema(siteUrl, "@nicobytes"),
  personSchema({
    name: "Nicolas Molina",
    url: siteUrl,
    description: homeDescription,
    sameAs: socialLinks.map((link) => link.href),
    jobTitle: "Senior Software Engineer",
  }),
];

---

<BaseLayout description={homeDescription} jsonLd={homeJsonLd}>
  <Container class="mt-9">
    <h1
      class="animate-fade-up inline-flex max-w-full items-baseline gap-1 text-[clamp(1.375rem,3.8vw,3rem)] font-bold tracking-tight whitespace-nowrap text-zinc-800 dark:text-zinc-100"
    >
      <span>Senior Software Engineer</span>
      <span
        class="inline-block h-[1.1em] w-[3px] shrink-0 translate-y-[0.1em] bg-teal-500 dark:bg-teal-400"
        style="animation: cursor-blink 1s step-end infinite;"
        aria-hidden="true"></span>
    </h1>
    <div class="mt-6 max-w-2xl">
      <p
        class="animate-fade-up text-base text-zinc-600 delay-1 dark:text-zinc-400"
      >
        I'm Nicolas Molina (@nicobytes) Sr Software Engineer with more than
        {yearsOfExperience} years of experience in development and technology management.
        Recognized by Google as an <a
          href="https://g.dev/nicobytes"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-accent-cyan text-teal-500 transition dark:text-teal-400"
          >Angular Developer Expert</a
        >, and by Microsoft as a <a
          class="hover:text-accent-cyan text-teal-500 transition dark:text-teal-400"
          target="_blank"
          rel="noopener noreferrer"
          href="https://mvp.microsoft.com/en-US/MVP/profile/28c464f4-ccb0-ec11-983f-000d3a1017e3"
          >Most Valuable Professional</a
        >.
      </p>
      <div class="animate-fade-up mt-6 flex gap-6 delay-2">
        {
          socialLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="group -m-1 p-1"
            >
              <Icon
                name={icon}
                class="group-hover:text-accent-cyan h-6 w-6 text-zinc-500 transition-all duration-200 group-hover:scale-110 group-hover:drop-shadow-[0_0_6px_rgba(6,182,212,0.4)] dark:text-zinc-400"
              />
            </a>
          ))
        }
      </div>
    </div>
  </Container>

  <div class="mt-16 sm:mt-20">
    <div class="-my-4 flex justify-center gap-5 overflow-hidden py-4 sm:gap-8">
      {
        heroPhotos.map((photo, index) => (
          <div
            class={clsx(
              "animate-fade-up relative w-44 flex-none overflow-hidden rounded-xl bg-zinc-100 transition-transform duration-300 ease-out hover:scale-105 sm:w-72 sm:rounded-2xl dark:bg-zinc-800",
              photo.rotation,
              `delay-${index + 3}`,
            )}
          >
            <div class="aspect-9/10">
              <Image
                src={photo.src}
                alt={photo.alt}
                widths={[352, 576, 864]}
                sizes="(min-width: 640px) 18rem, 11rem"
                quality={80}
                format="webp"
                loading={photo.loading}
                fetchpriority={photo.fetchpriority}
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <Container class="mt-24 md:mt-28">
    <div
      class="mx-auto grid max-w-xl grid-cols-1 gap-y-20 lg:max-w-none lg:grid-cols-2"
    >
      <div class="flex flex-col gap-16">
        {
          posts.map((post, i) => (
            <div class="scroll-reveal" style={`transition-delay: ${i * 0.1}s`}>
              <Card as="article">
                <CardTitle href={`/blog/${post.id}/`}>
                  {post.data.title}
                </CardTitle>
                <CardEyebrow as="time" dateTime={post.data.date} decorate>
                  {formatDate(post.data.date)}
                </CardEyebrow>
                <CardDescription>{post.data.description}</CardDescription>
                <CardCta>Read post</CardCta>
              </Card>
            </div>
          ))
        }
      </div>
      <div
        class="scroll-reveal space-y-10 lg:pl-16 xl:pl-24"
        style="transition-delay: 0.2s"
      >
        <!-- Newsletter 
        <form
          action="/thank-you"
          class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40"
        >
          <h2 class="flex text-sm font-semibold text-zinc-900 dark:text-zinc-100">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-6 w-6 flex-none">
              <path d="M2.75 7.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z" class="fill-zinc-100 stroke-zinc-400 dark:fill-zinc-100/10 dark:stroke-zinc-500" />
              <path d="m4 6 6.024 5.479a2.915 2.915 0 0 0 3.952 0L20 6" class="stroke-zinc-400 dark:stroke-zinc-500" />
            </svg>
            <span class="ml-3">Stay up to date</span>
          </h2>
          <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
            Get notified when I publish something new, and unsubscribe at any time.
          </p>
          <div class="mt-6 flex items-center">
            <span class="flex min-w-0 flex-auto p-px">
              <input
                type="email"
                placeholder="Email address"
                aria-label="Email address"
                required
                class="w-full appearance-none rounded-[calc(var(--radius-md)-1px)] bg-white px-3 py-[calc(var(--spacing-2,0.5rem)-1px)] shadow-md shadow-zinc-800/5 outline outline-zinc-900/10 placeholder:text-zinc-400 focus:ring-4 focus:ring-teal-500/10 focus:outline-teal-500 sm:text-sm dark:bg-zinc-700/15 dark:text-zinc-200 dark:outline-zinc-700 dark:placeholder:text-zinc-500 dark:focus:ring-teal-400/10 dark:focus:outline-teal-400"
              />
            </span>
            <Button type="submit" class="ml-4 flex-none">Join</Button>
          </div>
        </form> -->

        <Resume />
      </div>
    </div>
  </Container>
</BaseLayout>
