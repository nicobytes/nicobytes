---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BackButton from "../../components/BackButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import Prose from "../../components/Prose.astro";
import { getOgImageUrl } from "../../lib/getOgImageUrl";
import { creativeWorkSchema } from "../../lib/seo/jsonLd";

export async function getStaticPaths() {
  const projects = await getCollection("portfolio", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const ogImage = await getOgImageUrl(project.data.image, Astro.site);
const projectUrl = new URL(`/portfolio/${project.id}/`, Astro.site).href;
const jsonLd = creativeWorkSchema({
  title: project.data.title,
  description: project.data.description,
  url: projectUrl,
  image: ogImage,
  datePublished: project.data.date,
});
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={ogImage}
  jsonLd={jsonLd}
>
  <Container class="mt-12 lg:mt-24">
    <div class="xl:relative">
      <div class="mx-auto max-w-2xl">
        <BackButton href="/portfolio/" label="Back to portfolio" />
        <article>
          {
            project.data.image && (
              <figure class="mb-6 overflow-hidden rounded-2xl shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:ring-white/10">
                <Image
                  src={project.data.image}
                  alt={project.data.title}
                  widths={[672, 1024, 1344]}
                  sizes="(min-width: 42rem) 42rem, 100vw"
                  quality={85}
                  format="webp"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  class="h-auto w-full object-cover md:max-h-[540px]"
                />
              </figure>
            )
          }
          <header>
            <h1
              class="text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
            >
              {project.data.title}
            </h1>
          </header>
          <Prose class="mt-6" data-mdx-content>
            <Content />
          </Prose>
          {
            project.data.url && (
              <Button
                href={project.data.url}
                target="_blank"
                rel="noopener noreferrer"
                variant="secondary"
                class="group mt-8 w-full"
              >
                View project
                <svg
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                  class="h-4 w-4 stroke-zinc-400 transition group-active:stroke-zinc-600 dark:group-hover:stroke-zinc-50 dark:group-active:stroke-zinc-50"
                >
                  <path
                    d="M4.75 11.25 11.25 4.75M4.75 4.75h6.5v6.5"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </Button>
            )
          }
        </article>
      </div>
    </div>
  </Container>
</BaseLayout>
