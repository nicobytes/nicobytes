---
import { Icon } from "astro-icon/components";
import ContainerOuter from "./ContainerOuter.astro";
import ContainerInner from "./ContainerInner.astro";
import { navItems } from "../lib/navItems";
import { socialLinks } from "../lib/socialLinks";

const currentYear = new Date().getFullYear();
---

<footer class="mt-32 flex-none">
  <ContainerOuter>
    <div class="relative pt-10 pb-16">
      <div
        class="absolute inset-x-0 top-0 h-px"
        style="background: var(--accent-gradient); opacity: 0.3;"
      >
      </div>
      <ContainerInner>
        <div
          class="flex flex-col items-center justify-between gap-6 md:flex-row"
        >
          <div
            class="flex flex-wrap justify-center gap-x-6 gap-y-1 text-sm font-medium text-zinc-800 dark:text-zinc-200"
          >
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="hover:text-accent-cyan transition duration-200"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="flex items-center gap-4">
            {
              socialLinks.map(({ href, label, icon }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={label}
                  class="group"
                >
                  <Icon
                    name={icon}
                    class="group-hover:text-accent-cyan h-5 w-5 text-zinc-500 transition-all duration-200 group-hover:scale-110 dark:text-zinc-400"
                  />
                </a>
              ))
            }
          </div>
        </div>
        <p
          class="mt-6 text-center text-xs text-zinc-500 md:text-left dark:text-zinc-400"
        >
          &copy; {currentYear} Nicolas Molina. Built with Astro.
        </p>
      </ContainerInner>
    </div>
  </ContainerOuter>
</footer>
