---
interface Props {
  href: string;
  title: string;
  description: string;
  image: string;
}

const { href, title, description, image } = Astro.props;
---

<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 transition hover:ring-zinc-900/10 dark:bg-zinc-800/90 dark:ring-white/10 dark:hover:ring-white/20"
>
  <img
    src={image}
    alt={title}
    width={500}
    height={281}
    loading="lazy"
    decoding="async"
    class="aspect-video w-full object-cover"
  />
  <div class="flex flex-1 flex-col p-6">
    <h3
      class="text-base font-semibold text-zinc-800 group-hover:text-teal-500 dark:text-zinc-100 dark:group-hover:text-teal-400"
    >
      {title}
    </h3>
    <p class="mt-2 line-clamp-3 text-sm text-zinc-600 dark:text-zinc-400">
      {description}
    </p>
  </div>
</a>
