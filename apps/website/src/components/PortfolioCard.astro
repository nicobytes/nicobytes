---
interface Props {
  href: string;
  title: string;
  description: string;
  image: string;
}

const { href, title, description, image } = Astro.props;
---

<a
  href={href}
  class="gradient-border group hover:shadow-accent-cyan/10 flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 transition-all duration-300 ease-out hover:scale-[1.02] hover:shadow-lg hover:ring-zinc-900/10 dark:bg-zinc-800/90 dark:ring-white/10 dark:hover:ring-white/20"
>
  <div class="relative overflow-hidden">
    <img
      src={image}
      alt={title}
      width={500}
      height={281}
      loading="lazy"
      decoding="async"
      class="aspect-video w-full object-cover transition-transform duration-500"
    />
    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/30 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    >
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3
      class="group-hover:text-accent-cyan text-base font-semibold text-zinc-800 transition-colors duration-200 dark:text-zinc-100"
    >
      {title}
    </h3>
    <p class="mt-2 line-clamp-3 text-sm text-zinc-600 dark:text-zinc-400">
      {description}
    </p>
  </div>
</a>
