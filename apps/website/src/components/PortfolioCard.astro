---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  href: string;
  title: string;
  description: string;
  image: ImageMetadata;
}

const { href, title, description, image } = Astro.props;
---

<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 transition-all duration-300 ease-out hover:scale-[1.02] hover:shadow-lg hover:shadow-teal-500/10 hover:ring-teal-500/30 dark:bg-zinc-800/90 dark:ring-white/10 dark:hover:ring-teal-400/30"
>
  <div class="relative overflow-hidden">
    <Image
      src={image}
      alt={title}
      widths={[400, 600, 800]}
      sizes="(min-width: 1024px) 320px, (min-width: 640px) 50vw, 100vw"
      quality={80}
      format="webp"
      loading="lazy"
      decoding="async"
      class="aspect-video w-full object-cover transition-transform duration-500"
    />
    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/30 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
      aria-hidden="true"
    >
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3
      class="text-base font-semibold text-zinc-800 transition-colors duration-200 group-hover:text-teal-500 dark:text-zinc-100 dark:group-hover:text-teal-400"
    >
      {title}
    </h3>
    <p class="mt-2 line-clamp-3 text-sm text-zinc-600 dark:text-zinc-400">
      {description}
    </p>
  </div>
</a>
