---
import clsx from "clsx";
import { isNavItemActive, navItems } from "../lib/navItems";
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;
---

<div class="pointer-events-auto md:hidden">
  <button
    type="button"
    id="mobile-nav-toggle"
    aria-expanded="false"
    aria-controls="mobile-nav-panel"
    class="group flex min-h-11 min-w-11 items-center rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10 dark:hover:ring-white/20"
  >
    Menu
    <Icon
      name="line-md:chevron-down"
      aria-hidden="true"
      class="ml-3 h-3 w-3 text-zinc-500 group-hover:text-zinc-700 dark:group-hover:text-zinc-400"
    />
  </button>
</div>

<div
  id="mobile-nav-backdrop"
  class="pointer-events-auto fixed inset-0 z-50 hidden bg-zinc-800/40 opacity-0 backdrop-blur-xs transition-opacity duration-150 dark:bg-black/80"
  aria-hidden="true"
>
</div>

<div
  id="mobile-nav-panel"
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobile-nav-title"
  inert
  class="pointer-events-auto fixed inset-x-4 top-8 z-50 hidden origin-top scale-95 rounded-3xl bg-white p-8 opacity-0 ring-1 ring-zinc-900/5 transition duration-150 dark:bg-zinc-900 dark:ring-zinc-800"
>
  <div class="flex flex-row-reverse items-center justify-between">
    <button
      type="button"
      id="mobile-nav-close"
      aria-label="Close menu"
      class="flex min-h-11 min-w-11 cursor-pointer items-center justify-center rounded-full p-2"
    >
      <Icon
        name="line-md:close"
        aria-hidden="true"
        class="h-6 w-6 text-zinc-500 dark:text-zinc-400"
      />
    </button>
    <p
      id="mobile-nav-title"
      class="text-sm font-medium text-zinc-600 dark:text-zinc-400"
    >
      Navigation
    </p>
  </div>
  <nav class="mt-6" aria-label="Mobile">
    <ul
      class="-my-2 divide-y divide-zinc-100 text-base text-zinc-800 dark:divide-zinc-100/5 dark:text-zinc-300"
    >
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={clsx(
                "block py-2",
                isNavItemActive(currentPath, item.href) &&
                  "text-teal-500 dark:text-teal-400",
              )}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  const toggle = document.getElementById("mobile-nav-toggle")!;
  const backdrop = document.getElementById("mobile-nav-backdrop")!;
  const panel = document.getElementById("mobile-nav-panel")!;
  const closeBtn = document.getElementById("mobile-nav-close")!;
  const focusableSelector =
    'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  let previouslyFocused: HTMLElement | null = null;

  function getFocusableElements() {
    return Array.from(
      panel.querySelectorAll<HTMLElement>(focusableSelector),
    ).filter((el) => !el.hasAttribute("disabled") && el.offsetParent !== null);
  }

  function setExpanded(isOpen: boolean) {
    toggle.setAttribute("aria-expanded", String(isOpen));
    backdrop.setAttribute("aria-hidden", String(!isOpen));
  }

  function openNav() {
    previouslyFocused = document.activeElement as HTMLElement | null;
    backdrop.classList.remove("hidden");
    panel.classList.remove("hidden");
    panel.removeAttribute("inert");
    setExpanded(true);
    requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      panel.classList.remove("scale-95", "opacity-0");
      panel.classList.add("scale-100", "opacity-100");
      getFocusableElements()[0]?.focus();
    });
  }

  function closeNav() {
    backdrop.classList.add("opacity-0");
    panel.classList.remove("scale-100", "opacity-100");
    panel.classList.add("scale-95", "opacity-0");
    setExpanded(false);
    panel.setAttribute("inert", "");
    setTimeout(() => {
      backdrop.classList.add("hidden");
      panel.classList.add("hidden");
      previouslyFocused?.focus();
    }, 150);
  }

  toggle.addEventListener("click", openNav);
  closeBtn.addEventListener("click", closeNav);
  backdrop.addEventListener("click", closeNav);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
      event.preventDefault();
      closeNav();
      return;
    }

    if (
      event.key !== "Tab" ||
      toggle.getAttribute("aria-expanded") !== "true"
    ) {
      return;
    }

    const focusable = getFocusableElements();
    if (focusable.length === 0) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement;

    if (event.shiftKey && active === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && active === last) {
      event.preventDefault();
      first.focus();
    }
  });
</script>
