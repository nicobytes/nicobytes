---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
}

const { src, alt } = Astro.props;

const lightbox = await getImage({
  src,
  width: 1344,
  format: "webp",
  quality: 90,
});
---

<button
  type="button"
  data-lightbox-trigger
  data-lightbox-src={lightbox.src}
  data-lightbox-alt={alt}
  class="group block w-full rounded-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 max-md:cursor-default md:cursor-zoom-in disabled:cursor-default disabled:opacity-100"
>
  <Image
    src={src}
    alt={alt}
    widths={[672, 1024, 1344]}
    sizes="(min-width: 42rem) 42rem, 100vw"
    quality={80}
    format="webp"
    loading="lazy"
    decoding="async"
    class="h-auto w-full rounded-lg transition md:group-hover:opacity-95"
  />
</button>
