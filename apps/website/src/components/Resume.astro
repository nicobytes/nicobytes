---
import { Image } from "astro:assets";

import logoDotCMS from "../assets/images/logos/dotcms.png";
import logoPlatzi from "../assets/images/logos/platzi.png";
import logoSenseta from "../assets/images/logos/senseta.png";
import logoSponzorMe from "../assets/images/logos/sponzorme.png";
import logo3Dementes from "../assets/images/logos/3d.png";
import logoHarMec from "../assets/images/logos/harmec.png";

type ResumeEntry = {
  company: string;
  title: string;
  logo: ImageMetadata;
  start: string;
  end: string;
};

const resume: ResumeEntry[] = [
  {
    company: "dotCMS",
    title: "Senior Front-end Developer",
    logo: logoDotCMS,
    start: "2024",
    end: "Present",
  },
  {
    company: "Platzi",
    title: "Senior Full-stack Developer",
    logo: logoPlatzi,
    start: "2020",
    end: "2024",
  },
  {
    company: "Senseta",
    title: "Tech Lead & Full-stack Developer",
    logo: logoSenseta,
    start: "2017",
    end: "2020",
  },
  {
    company: "SponzorMe",
    title: "Angular/Ionic Developer",
    logo: logoSponzorMe,
    start: "2016",
    end: "2017",
  },
  {
    company: "3Dementes",
    title: "Web Developer",
    logo: logo3Dementes,
    start: "2015",
    end: "2016",
  },
  {
    company: "HarMec",
    title: "Web Developer",
    logo: logoHarMec,
    start: "2013",
    end: "2015",
  },
];
---

<div class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40">
  <h2 class="flex px-4 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="h-6 w-6 flex-none"
    >
      <path
        d="M2.75 9.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z"
        class="fill-zinc-100 stroke-zinc-400 dark:fill-zinc-100/10 dark:stroke-zinc-500"
      ></path>
      <path
        d="M3 14.25h6.249c.484 0 .952-.002 1.316.319l.777.682a.996.996 0 0 0 1.316 0l.777-.682c.364-.32.832-.319 1.316-.319H21M8.75 6.5V4.75a2 2 0 0 1 2-2h2.5a2 2 0 0 1 2 2V6.5"
        class="stroke-zinc-400 dark:stroke-zinc-500"></path>
    </svg>
    <span class="ml-3">Work</span>
  </h2>
  <ol class="relative mt-6 space-y-4">
    <div
      class="from-accent-cyan/40 via-accent-emerald/20 absolute top-2 bottom-2 left-7 w-px -translate-x-1/2 bg-linear-to-b to-transparent"
      aria-hidden="true"
    >
    </div>
    {
      resume.map((role) => (
        <li class="relative flex gap-4 rounded-lg px-2 py-1 transition-colors duration-200 hover:bg-zinc-50 dark:hover:bg-zinc-800/50">
          <div class="relative z-10 mt-1 flex h-10 w-10 flex-none items-center justify-center overflow-hidden rounded-full shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0">
            <Image
              src={role.logo}
              alt=""
              width={40}
              height={40}
              class="h-full w-full object-cover"
            />
          </div>
          <dl class="flex flex-auto flex-wrap gap-x-2">
            <dt class="sr-only">Company</dt>
            <dd class="w-full flex-none text-sm font-medium text-zinc-900 dark:text-zinc-100">
              {role.company}
            </dd>
            <dt class="sr-only">Role</dt>
            <dd class="text-xs text-zinc-500 dark:text-zinc-400">
              {role.title}
            </dd>
            <dt class="sr-only">Date</dt>
            <dd
              class="ml-auto text-xs text-zinc-400 dark:text-zinc-500"
              aria-label={`${role.start} until ${role.end}`}
            >
              <time datetime={role.start}>{role.start}</time>{" "}
              <span aria-hidden="true">—</span>{" "}
              <time datetime={role.end}>{role.end}</time>
            </dd>
          </dl>
        </li>
      ))
    }
  </ol>
</div>
