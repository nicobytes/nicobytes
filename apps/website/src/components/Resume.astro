---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import logoDotCMS from "../assets/images/logos/dotcms.png";
import logoPlatzi from "../assets/images/logos/platzi.png";
import logoSenseta from "../assets/images/logos/senseta.png";
import logoSponzorMe from "../assets/images/logos/sponzorme.png";
import logo3Dementes from "../assets/images/logos/3d.png";
import logoHarMec from "../assets/images/logos/harmec.png";

type ResumeEntry = {
  company: string;
  title: string;
  logo: ImageMetadata;
  start: string;
  end: string;
};

const resume: ResumeEntry[] = [
  {
    company: "dotCMS",
    title: "Senior Front-end Developer",
    logo: logoDotCMS,
    start: "2024",
    end: "Present",
  },
  {
    company: "Platzi",
    title: "Senior Full-stack Developer",
    logo: logoPlatzi,
    start: "2020",
    end: "2024",
  },
  {
    company: "Senseta",
    title: "Tech Lead & Full-stack Dev",
    logo: logoSenseta,
    start: "2017",
    end: "2020",
  },
  {
    company: "SponzorMe",
    title: "Angular/Ionic Developer",
    logo: logoSponzorMe,
    start: "2016",
    end: "2017",
  },
  {
    company: "3Dementes",
    title: "Web Developer",
    logo: logo3Dementes,
    start: "2015",
    end: "2016",
  },
  {
    company: "HarMec",
    title: "Web Developer",
    logo: logoHarMec,
    start: "2013",
    end: "2015",
  },
];
---

<div class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40">
  <h2 class="flex px-4 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
    <Icon name="line-md:briefcase-check" class="h-6 w-6 flex-none" />
    <span class="ml-3">Work</span>
  </h2>
  <ol class="relative mt-6 space-y-4">
    <div
      class="from-accent-cyan/40 via-accent-emerald/20 absolute top-2 bottom-2 left-7 w-px -translate-x-1/2 bg-linear-to-b to-transparent"
      aria-hidden="true"
    >
    </div>
    {
      resume.map((role) => (
        <li class="relative flex gap-4 rounded-lg px-2 py-1 transition-colors duration-200 hover:bg-zinc-50 dark:hover:bg-zinc-800/50">
          <div class="relative z-10 mt-1 flex h-10 w-10 flex-none items-center justify-center overflow-hidden rounded-full shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0">
            <Image
              src={role.logo}
              alt=""
              width={40}
              height={40}
              class="h-full w-full object-cover"
            />
          </div>
          <dl class="flex min-w-0 flex-auto flex-col">
            <dt class="sr-only">Company</dt>
            <dd class="text-sm font-medium text-zinc-900 dark:text-zinc-100">
              {role.company}
            </dd>
            <div class="mt-0.5 flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-x-3">
              <dt class="sr-only">Role</dt>
              <dd class="min-w-0 text-xs text-zinc-500 dark:text-zinc-400">
                {role.title}
              </dd>
              <dt class="sr-only">Date</dt>
              <dd
                class="shrink-0 text-xs whitespace-nowrap text-zinc-400 sm:text-right dark:text-zinc-500"
                aria-label={`${role.start} until ${role.end}`}
              >
                <time datetime={role.start}>{role.start}</time>{" "}
                <span aria-hidden="true">—</span>{" "}
                <time datetime={role.end}>{role.end}</time>
              </dd>
            </div>
          </dl>
        </li>
      ))
    }
  </ol>
</div>
