---
import Container from "./Container.astro";

interface Props {
  title: string;
  intro: string;
}

const { title, intro } = Astro.props;
---

<Container class="mt-16 sm:mt-32">
  <header class="max-w-2xl">
    <h1
      class="animate-fade-up text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100"
    >
      {title}
    </h1>
    <p
      class="animate-fade-up mt-6 text-base text-zinc-600 delay-1 dark:text-zinc-400"
    >
      {intro}
    </p>
  </header>
  <div class="animate-fade-up mt-16 delay-2 sm:mt-20">
    <slot />
  </div>
</Container>
