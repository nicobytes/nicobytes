---
import type { CollectionEntry } from 'astro:content';

interface Props {
  workshop: CollectionEntry<'workshops'>;
  index: number;
}

const { workshop, index } = Astro.props;
const { title, description, level, tags } = workshop.data;
const href = `/workshops/${workshop.id}`;
---

<article
  class="animate-fade-up group py-10"
  style={`animation-delay: ${index * 80}ms`}
>
  <a href={href} class="block" data-astro-prefetch>
    <h2
      class="font-display text-2xl font-semibold tracking-tight text-text transition-colors group-hover:text-accent md:text-3xl"
    >
      {title}
    </h2>

    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-xs text-faint">
      {
        level && (
          <span class="uppercase tracking-[0.18em] text-muted">{level}</span>
        )
      }
      {
        tags?.map((tag) => (
          <span class="text-faint">{tag}</span>
        ))
      }
    </div>

    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted">
      {description}
    </p>
  </a>
</article>
