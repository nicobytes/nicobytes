---
import type { CollectionEntry } from 'astro:content';

interface Props {
  workshop: CollectionEntry<'workshops'>;
  index: number;
  href: string;
}

const { workshop, index, href } = Astro.props;
const { title, description, level, tags } = workshop.data;
---

<article
  class="animate-fade-up group py-10"
  style={`animation-delay: ${index * 80}ms`}
>
  <a href={href} class="block" data-astro-prefetch>
    <div class="flex items-baseline gap-4">
      <span class="font-mono text-xs tabular-nums text-faint">
        {String(index + 1).padStart(2, '0')}
      </span>
      <h2
        class="text-lg font-medium tracking-tight text-text/90 transition-colors group-hover:text-accent md:text-xl"
      >
        {title}
      </h2>
    </div>

    <div
      class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 pl-9 font-mono text-xs text-faint"
    >
      {
        level && (
          <span class="uppercase tracking-[0.18em] text-muted">{level}</span>
        )
      }
      {
        tags?.map((tag) => (
          <span class="text-faint">{tag}</span>
        ))
      }
    </div>

    <p class="mt-4 max-w-2xl pl-9 text-sm leading-relaxed text-muted md:text-base">
      {description}
    </p>
  </a>
</article>
