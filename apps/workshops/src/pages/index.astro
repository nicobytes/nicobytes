---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkshopCard from '../components/WorkshopCard.astro';
import { getStepHref, getWorkshopSteps } from '../lib/workshops';

const workshops = (await getCollection('workshops')).sort(
  (a, b) => a.data.order - b.data.order,
);
const steps = await getCollection('steps');
---

<BaseLayout>
  <main class="mx-auto min-h-screen max-w-3xl px-6 py-16 md:px-8 md:py-24">
    <header class="mb-16 animate-fade-up md:mb-20">
      <p class="font-mono text-xs uppercase tracking-[0.24em] text-faint">
        Technical workshops
      </p>
      <h1
        class="font-display mt-4 text-5xl font-bold leading-none tracking-tighter text-text md:text-6xl"
      >
        Workshops
      </h1>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-muted">
        Guías paso a paso para aprender haciendo. Elige un taller y avanza a tu
        ritmo.
      </p>
    </header>

    <div class="list-divider mb-10"></div>

    <section>
      <p
        class="mb-8 font-mono text-[10px] uppercase tracking-[0.22em] text-faint"
      >
        Talleres disponibles
      </p>

      {
        workshops.map((workshop, index) => {
          const workshopSteps = getWorkshopSteps(steps, workshop.id);
          const firstStep = workshopSteps[0];
          const href = firstStep
            ? getStepHref(workshop.id, firstStep)
            : `/${workshop.id}`;

          return (
            <div>
              {index > 0 && <div class="list-divider" />}
              <WorkshopCard workshop={workshop} index={index} href={href} />
            </div>
          );
        })
      }
    </section>

    <footer class="list-divider mt-4 pt-8">
      <p class="font-mono text-xs text-faint">© {new Date().getFullYear()}</p>
    </footer>
  </main>
</BaseLayout>
